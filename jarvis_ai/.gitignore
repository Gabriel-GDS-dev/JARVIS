# ============================================================
# .gitignore — Jarvis AI
# ============================================================

# Ambiente virtual Python
venv/
.venv/
env/
ENV/

# Arquivos executáveis e instaladores GRANDES
*.exe
*.msi
*.dmg
*.iso
*.zip
*.rar
*.7z
*.tar.gz

# Modelos de IA e dados
models/
*.bin
*.safetensors
*.ck
*.ckpt
*.pth
*.pt

# Ollama
ollama/
.ollama/

# Banco de dados
*.db
*.sqlite
*.sqlite3
data/*.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Arquivos de upload
data/uploads/*
!data/uploads/.gitkeep

# Variáveis de ambiente
.env
.env.local
.env.*.local

# Cache
*.cache
.cache/

# OS
Thumbs.db
.DS_Store
