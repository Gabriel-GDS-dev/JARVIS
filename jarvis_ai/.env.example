# ============================================================
# CONFIGURAÇÕES DO JARVIS AI
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Nome da sua IA
JARVIS_NAME=Jarvis

# Modelo Ollama a ser usado (escolha um que você baixou)
# Opções: llama3, mistral, gemma, phi, codellama
OLLAMA_MODEL=llama3

# URL onde o Ollama está rodando (padrão local)
OLLAMA_BASE_URL=http://localhost:11434

# Banco de dados (caminho do arquivo SQLite)
DATABASE_URL=sqlite:///./data/app.db

# Ambiente: development ou production
ENVIRONMENT=development

# Porta da API
API_PORT=8000

# Máximo de mensagens do histórico enviadas ao modelo
MAX_HISTORY_MESSAGES=20

# Máximo de memórias incluídas no contexto
MAX_MEMORIES_CONTEXT=10
